      <CodeComponent name="retryGate" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="if ((! endOfBlock)) {&amp;#10;    continueRoutine = false;&amp;#10;} else {&amp;#10;    accuracy = ((nBlockTrials &gt; 0) ? (nCorrect / Number.parseFloat(nBlockTrials)) : 0.0);&amp;#10;    psychoJS.experiment.addData(&quot;ucf5_accuracy&quot;, accuracy);&amp;#10;    passedBlock = (accuracy &gt;= UCF5_THRESH);&amp;#10;    if (passedBlock) {&amp;#10;        msg = `Accuracy: ${util.pad(Number.parseFloat((accuracy * 100)).toFixed(0), 1)}%&amp;#10;Great! Press SPACE to continue.`&amp;#10;;&amp;#10;    } else {&amp;#10;        msg = `Accuracy: ${util.pad(Number.parseFloat((accuracy * 100)).toFixed(0), 1)}%&amp;#10;Please try again.`&amp;#10;;&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="# sadece blok bittiğinde bu ekranı göster&amp;#10;if not endOfBlock:&amp;#10;    continueRoutine = False&amp;#10;else:&amp;#10;    # mesajı BAŞTA hazırla ki ekranda görünsün&amp;#10;    accuracy = (nCorrect / float(nBlockTrials)) if nBlockTrials &gt; 0 else 0.0&amp;#10;    thisExp.addData('ucf5_accuracy', accuracy)&amp;#10;&amp;#10;    passedBlock = (accuracy &gt;= UCF5_THRESH)&amp;#10;    if passedBlock:&amp;#10;        msg = f&quot;Accuracy: {accuracy*100:.0f}%\nGreat! Press SPACE to continue.&quot;&amp;#10;    else:&amp;#10;        msg = f&quot;Accuracy: {accuracy*100:.0f}%\nPlease try again.&quot;&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="if (endOfBlock) {&amp;#10;    accuracy = ((nBlockTrials &gt; 0) ? (nCorrect / Number.parseFloat(nBlockTrials)) : 0.0);&amp;#10;    psychoJS.experiment.addData(&quot;ucf5_accuracy&quot;, accuracy);&amp;#10;    if ((accuracy &gt;= UCF5_THRESH)) {&amp;#10;        ucf5TestLoop.finished = true;&amp;#10;        msg = `Accuracy: ${util.pad(Number.parseFloat((accuracy * 100)).toFixed(0), 1)}%&amp;#10;Great! Press SPACE to continue.`&amp;#10;;&amp;#10;    } else {&amp;#10;        nTotal = 0;&amp;#10;        nCorrect = 0;&amp;#10;        trialInBlock = 0;&amp;#10;        endOfBlock = false;&amp;#10;        showIntro = false;&amp;#10;        msg = `Accuracy: ${util.pad(Number.parseFloat((accuracy * 100)).toFixed(0), 1)}%&amp;#10;Please try again.`&amp;#10;;&amp;#10;    }&amp;#10;}&amp;#10;if (endOfBlock) {&amp;#10;    if (passedBlock) {&amp;#10;        ucf5TestLoop.finished = true;&amp;#10;    } else {&amp;#10;        reset_block();&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="if endOfBlock:&amp;#10;    accuracy = (nCorrect / float(nBlockTrials)) if nBlockTrials &gt; 0 else 0.0&amp;#10;    thisExp.addData('ucf5_accuracy', accuracy)&amp;#10;&amp;#10;    if accuracy &gt;= UCF5_THRESH:&amp;#10;        ucf5TestLoop.finished = True&amp;#10;        msg = f&quot;Accuracy: {accuracy*100:.0f}%\nGreat! Press SPACE to continue.&quot;&amp;#10;    else:&amp;#10;        # yalnız video+response tekrar edilsin (talimat/break yok)&amp;#10;        nTotal = 0&amp;#10;        nCorrect = 0&amp;#10;        trialInBlock = 0&amp;#10;        endOfBlock = False&amp;#10;        showIntro = False&amp;#10;        msg = f&quot;Accuracy: {accuracy*100:.0f}%\nPlease try again.&quot;&amp;#10;if endOfBlock:&amp;#10;    if passedBlock:&amp;#10;        ucf5TestLoop.finished = True&amp;#10;    else:&amp;#10;        reset_block()        # nTotal/nCorrect/trialInBlock sıfırlansın, showIntro=False&amp;#10;&amp;#10;" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="retryGate" valType="code" updates="None" name="name"/>
      </CodeComponent>
