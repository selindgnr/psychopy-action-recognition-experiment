        <Param val="try:&amp;#10;    import pandas as pd&amp;#10;    with pd.ExcelWriter(xlsx_out) as writer:&amp;#10;        for sheet, rows in agg_rows.items():&amp;#10;            if rows:  # only write sheets that have data&amp;#10;                df = pd.DataFrame(rows, columns=['video_id','correct_ans','participant_ans','response_RT'])&amp;#10;                df.to_excel(writer, sheet_name=sheet.upper(), index=False)&amp;#10;    print(f&quot;[OK] Saved results to: {xlsx_out}&quot;)&amp;#10;except Exception as e:&amp;#10;    # Fallback: write 3 CSVs if Excel writer isn't available&amp;#10;    import csv&amp;#10;    for sheet, rows in agg_rows.items():&amp;#10;        if rows:&amp;#10;            csv_path = os.path.join(_thisDir, 'data', f&quot;{fileBase}_{sheet}.csv&quot;)&amp;#10;            with open(csv_path, 'w', newline='', encoding='utf-8') as f:&amp;#10;                w = csv.DictWriter(f, fieldnames=['video_id','correct_ans','participant_ans','response_RT'])&amp;#10;                w.writeheader(); w.writerows(rows)&amp;#10;    print(f&quot;[WARN] Could not write Excel ({e}). Wrote CSVs instead.&quot;)&amp;#10;" valType="extendedCode" updates="constant" name="End Experiment"/>
