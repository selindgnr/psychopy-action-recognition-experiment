        <Param val="Classify the action:&amp;#10;1 = JumpingJack&amp;#10;2 = Lunges&amp;#10;3 = PullUps&amp;#10;4 = PushUps&amp;#10;5 = Swing" valType="str" updates="constant" name="text"/>
        <Param val="from exp settings" valType="str" updates="None" name="units"/>
