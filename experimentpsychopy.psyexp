        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="if ((testResponse.keys === correct_ans.toString())) {&amp;#10;    correct = 1;&amp;#10;} else {&amp;#10;    correct = 0;&amp;#10;}&amp;#10;psychoJS.experiment.addData(&quot;correct&quot;, correct);&amp;#10;psychoJS.experiment.addData(&quot;given_answer&quot;, testResponse.keys);&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
